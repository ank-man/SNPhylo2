// SNPhylo2 Nextflow Configuration

manifest {
    name = 'SNPhylo2'
    author = 'Ankush Sharma'
    description = 'Next-generation phylogenomic pipeline from SNP data'
    version = '0.1.0'
    nextflowVersion = '>=21.0.0'
    mainScript = 'main.nf'
}

// Default parameters
params {
    help = false
    version = false
    
    // Input/Output
    input = null
    output = 'results'
    config = null
    
    // Compute
    threads = 4
    
    // Filtering
    maf = 0.05
    max_missing = 0.2
    min_depth = 5
    
    // LD Pruning
    ld_window = 50
    ld_step = 10
    ld_r2 = 0.2
    
    // Tree Building
    tree_engine = 'iqtree2'
    bootstrap = 1000
}

// Process configuration
process {
    // Default error strategy
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 3
    
    // Resource labels
    withLabel: 'low_mem' {
        cpus = 2
        memory = 4.GB
        time = 1.h
    }
    
    withLabel: 'medium_mem' {
        cpus = 4
        memory = 8.GB
        time = 4.h
    }
    
    withLabel: 'high_mem' {
        cpus = 8
        memory = 16.GB
        time = 8.h
    }
    
    withLabel: 'high_cpu' {
        cpus = 16
        memory = 32.GB
        time = 12.h
    }
}

// Profiles
profiles {
    // Local execution (default)
    local {
        process.executor = 'local'
    }
    
    // SLURM cluster
    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
        process.clusterOptions = '--account=your_account'
        
        // Adjust resources for cluster
        process {
            withLabel: 'low_mem' {
                cpus = 2
                memory = 4.GB
                time = 2.h
                queue = 'short'
            }
            
            withLabel: 'medium_mem' {
                cpus = 4
                memory = 8.GB
                time = 8.h
                queue = 'normal'
            }
            
            withLabel: 'high_mem' {
                cpus = 8
                memory = 32.GB
                time = 24.h
                queue = 'long'
            }
            
            withLabel: 'high_cpu' {
                cpus = 16
                memory = 64.GB
                time = 48.h
                queue = 'long'
            }
        }
    }
    
    // PBS/Torque
    pbs {
        process.executor = 'pbs'
        process.queue = 'default'
    }
    
    // SGE
    sge {
        process.executor = 'sge'
        process.queue = 'all.q'
    }
    
    // AWS Batch
    aws {
        process.executor = 'awsbatch'
        process.queue = 'snphylo2-queue'
        workDir = 's3://your-bucket/work'
        
        aws {
            region = 'us-east-1'
        }
    }
    
    // Google Cloud Life Sciences
    gcp {
        process.executor = 'google-lifesciences'
        workDir = 'gs://your-bucket/work'
        
        google {
            project = 'your-project-id'
            zone = 'us-central1-b'
        }
    }
    
    // Docker
    docker {
        docker.enabled = true
        process.container = 'ghcr.io/snphylo2/snphylo2:latest'
    }
    
    // Singularity
    singularity {
        singularity.enabled = true
        process.container = 'ghcr.io/snphylo2/snphylo2:latest'
        singularity.cacheDir = './singularity_cache'
    }
    
    // Test profile (small resources, fast)
    test {
        params.threads = 2
        
        process {
            cpus = 2
            memory = 4.GB
            time = 30.m
        }
    }
}

// Reporting
dag {
    enabled = true
    file = 'pipeline_dag.html'
}

report {
    enabled = true
    file = 'pipeline_report.html'
}

timeline {
    enabled = true
    file = 'pipeline_timeline.html'
}

trace {
    enabled = true
    file = 'pipeline_trace.txt'
    fields = 'task_id,name,status,exit,realtime,%cpu,%mem'
}

// Notification (optional)
notification {
    enabled = false
    to = 'your-email@example.com'
}
